{
  "ConnectionStrings": {
    "Postgres": "Host=localhost;Port=5432;Database=esar;Username=esar;Password=CHANGE_ME",
    "Redis": ""
  },
  "RabbitMq": {
    "Host": "",
    "Port": 5672,
    "Username": "esar",
    "Password": "CHANGE_ME",
    "Exchange": "esar.events"
  },
  "Jwt": {
    "Issuer": "esar",
    "Audience": "esar-clients",
    "SigningKey": "",
    "TokenLifetimeMinutes": 60
  },
  "Security": {
    "EncryptionKey": ""
  },
  "Smtp": {
    "Host": "localhost",
    "Port": 587,
    "UseSsl": true,
    "FromAddress": "esar@example.com",
    "FromName": "ESAR Platform"
  },
  "ServiceNow": { "Enabled": false },
  "Jira": { "Enabled": false },
  "Cors": {
    "AllowedOrigins": [ "http://localhost:5173", "http://localhost:8080" ]
  },
  "RateLimiting": { "PermitLimit": 300 },
  "Database": { "AutoMigrate": true },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning"
      }
    },
    "WriteTo": [
      { "Name": "Console" },
      {
        "Name": "File",
        "Args": {
          "path": "logs/esar-api-.log",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 14
        }
      }
    ]
  },
  "AllowedHosts": "*"
}
