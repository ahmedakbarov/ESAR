{
  "ConnectionStrings": {
    "Postgres": "Host=localhost;Port=5432;Database=esar;Username=esar;Password=CHANGE_ME",
    "Redis": ""
  },
  "RabbitMq": {
    "Host": "",
    "Port": 5672,
    "Username": "esar",
    "Password": "CHANGE_ME",
    "Exchange": "esar.events"
  },
  "Jwt": { "Issuer": "esar", "Audience": "esar-clients", "SigningKey": "unused-in-workers-but-must-be-32-chars!!" },
  "Security": { "EncryptionKey": "" },
  "Smtp": {
    "Host": "localhost",
    "Port": 587,
    "UseSsl": true,
    "FromAddress": "esar@example.com",
    "FromName": "ESAR Platform"
  },
  "ServiceNow": { "Enabled": false },
  "Jira": { "Enabled": false },
  "Hangfire": { "WorkerCount": 5 },
  "Database": { "AutoMigrate": false },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": { "Microsoft": "Warning", "Hangfire": "Information" }
    },
    "WriteTo": [
      { "Name": "Console" },
      {
        "Name": "File",
        "Args": {
          "path": "logs/esar-workers-.log",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 14
        }
      }
    ]
  }
}
