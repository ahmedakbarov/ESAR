# ESAR — environment template
# ----------------------------
# Copy this file to `.env` and fill in real values BEFORE running docker compose:
#
#   cp .env.example .env
#
# `.env` is git-ignored and must NEVER be committed. Every value below is a
# placeholder — replace all of them. The base compose file fails fast (`:?`) if
# a required secret is missing, so an empty value will stop the stack on purpose.
#
# Generate strong secrets on the host (Linux/macOS):
#   openssl rand -base64 48        # JWT_SIGNING_KEY
#   openssl rand -base64 32        # ENCRYPTION_KEY  (must decode to 32 bytes)
#   openssl rand -base64 24        # POSTGRES_PASSWORD / RABBITMQ_PASSWORD / ADMIN_PASSWORD
# On Windows PowerShell:
#   [Convert]::ToBase64String((1..32 | % {Get-Random -Max 256}))


# ============================================================================
# REQUIRED — base stack (docker-compose.yml). The stack will not start without these.
# ============================================================================

# PostgreSQL password for user `esar` (database `esar`).
# NOTE: if you change this after the postgres volume already exists, the DB will
# reject the new password. Either keep it, or recreate with `docker compose down -v`.
POSTGRES_PASSWORD=replace-with-strong-password

# RabbitMQ password for user `esar`.
RABBITMQ_PASSWORD=replace-with-strong-password

# JWT signing key (HS256). Use at least 32 bytes of entropy — `openssl rand -base64 48`.
# Rotating this invalidates all issued tokens (every user must log in again).
JWT_SIGNING_KEY=replace-with-random-48-byte-base64-string

# AES-256-GCM key protecting stored connector secrets. Must base64-decode to
# exactly 32 bytes — `openssl rand -base64 32`.
#
# ⚠  CRITICAL: for an EXISTING deployment this MUST stay the SAME value it was
#    first deployed with. Changing it makes every already-stored connector
#    secret (Azure client secret, AD bind password, Cortex API key, …)
#    permanently UNDECRYPTABLE — you would have to re-enter every connector.
#    Only generate a fresh key for a brand-new install with no saved connectors.
ENCRYPTION_KEY=replace-with-random-32-byte-base64-key

# Initial password for the seeded `admin` user. Used ONLY on first startup to
# create the admin account, then change it in the UI. It is never logged.
ADMIN_PASSWORD=replace-with-strong-admin-password


# ============================================================================
# DEPLOYMENT
# ============================================================================

# Development (default) enables Swagger and relaxed settings. Set to Production
# for real deployments (the prod overlay also forces this).
ASPNETCORE_ENVIRONMENT=Development

# Public DNS name for automatic HTTPS via Caddy (docker-compose.prod.yml).
# Leave commented / unset to serve plain HTTP on :80 (local/private test only).
# ESAR_DOMAIN=esar.example.com


# ============================================================================
# AZURE AD SSO login (optional)
# ============================================================================
# Lets users sign in with "Sign in with Microsoft" instead of (or alongside) a
# local password. Requires an Azure App Registration you create yourself:
#   - Platform: Single-page application (SPA)
#   - Redirect URI: the origin ESAR is served from (e.g. https://esar.example.com)
#   - API permissions: openid, profile, email (no custom API scope needed)
# Leave both blank to keep Azure AD SSO disabled — /auth/login/entra returns
# "Entra ID SSO is not configured." and the frontend hides the Microsoft button.
# ENTRAID_TENANT_ID=00000000-0000-0000-0000-000000000000
# ENTRAID_CLIENT_ID=00000000-0000-0000-0000-000000000000

# When true, a first successful Entra ID/AD login auto-creates an ESAR account
# (Viewer role) for an identity with no admin-pre-provisioned or previously-
# linked account. Defaults to false — leave off unless every domain/tenant
# account should get an ESAR account automatically. Toggle later without a
# redeploy via PUT /api/v1/settings/auth.federated.autoProvision.
# AUTH_FEDERATED_AUTOPROVISION=false


# ============================================================================
# ACTIVE DIRECTORY / LDAPS overlays (optional)
# ============================================================================
# Only needed when you add the AD overlay files to the compose chain, e.g.:
#   docker compose -f docker-compose.yml -f docker-compose.prod.yml \
#                  -f docker-compose.ad-ldaps.yml -f docker-compose.ad-hosts.yml \
#                  --env-file .env up -d --build
#
# The AD connector enforces LDAPS. The container must trust the DC's CA and be
# able to resolve/reach the DC by the exact name on its certificate.

# docker-compose.ad-ldaps.yml — absolute HOST path to a PEM CA bundle that
# issued the DC's LDAPS certificate. Mounted read-only into API + workers.
AD_LDAPS_CA_FILE=/opt/esar/ldaps/ad-ldaps-ca-bundle.pem

# docker-compose.ad-hosts.yml — DC FQDN (must EXACTLY match a DNS name in the
# DC's LDAPS certificate) and its private IP. Test-only DNS fallback.
AD_DC_FQDN=dc01.esar.local
AD_DC_IP=172.16.0.5

# docker-compose.ad-dns.yml — private AD DNS server IP. Use only when Docker
# cannot resolve the AD domain; prefer Azure VNet DNS integrated with AD DNS.
AD_DNS_SERVER=172.16.0.5
